SHELL=/bin/sh
NAME=	eliteeq
CMD=    $(NAME)
#
SRCS= init.f90 eliteeq.f90 gendat.f90 rdeqdsk.f90 mapperb.f90 spline2d.f output.f90 furplm.f sortstuff.f rayatt.f cntourp.f readbal.f90 readeq.f90 readgato.f90 readpest.f90
#
#INCL=	i_equil.f
#
#OBJS=   $(SRCS:.f=.o)
OBJS= init.o eliteeq.o gendat.o rdeqdsk.o mapperb.o spline2d.o output.o furplm.o sortstuff.o rayatt.o cntourp.o readbal.o readeq.o readgato.o readpest.o
#
INPUT=	
#-octane-----------------------------------------------------------------
LIBRARIES = -lrlm #-lblas #-lghost -lgrid_xghost -lnag 
DEBUG     = #  -g -check_bounds
OPTIMIZE  = -O # -O3 
LISTING   = # -listing
SPECIAL   = -L../libdbl -lU77 # -p
DOUBLE    = -N113 #-qautodbl=dblpad
COMPILE   = f95 -c $(LISTING) $(SPECIAL) $(DOUBLE) $(OPTIMIZE)
LOAD      = f95 $(SPECIAL) -o $(CMD) $(LIBS)
ARCHIVE   = ar rv
CATALOG   = ar tv
#
.SUFFIXES:

.SUFFIXES: .o .f .f90

all: $(CMD)
	@echo
	@echo ">>  `date '+%a %d-%h-%y %r'`  `pwd`  `uname -mns`  $(LOGNAME)"

$(CMD):         $(OBJS) 
	$(LOAD) $(OBJS) $(LIBRARIES)
	chmod 755 $(CMD)

#$(SRCS):	$(INCL)
#	touch $(SRCS)

#.f.o:	$(SRCS)
#	$(COMPILE) $?
.f.o:	
	$(COMPILE) $<

.f90.o:	
	$(COMPILE) $<
#-------------------------------------------------------------------------
clean:
	rm -f $(CMD) *.a *.o

tarfile:
	tar cfv $(NAME).tar makefile $(INPUT) $(INCL) $(SRCS) 

