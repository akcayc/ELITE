DEBUG     = #  -g -check_bounds
OPTIMIZE  = #-fast -static # -tp= x64 #-Mipa=fast,inline  #-fast # -fast -tp x64 #-O3 #-O5 # -O3 
#OPTIMIZE  = -O5 -arch ev6 -tune ev6 -math_library fast -align dcommons -assume bigarrays -assume nozsize
LISTING   = # -listing
#SPECIAL   = -L../libdbl64 -L../libblas64_test -L../libSpecFun64 -L/usr/lib64 # -Bstatic -L/usr/local/lf9562/lib --staticlink #-L/d/osf/lib/# -p
#SPECIAL   = -L /fusion/usc/opt/intel/compilers_and_libraries_2016.3.210/linux/compiler/lib/intel64 -L /fusion/usc/opt/intel/compilers_and_libraries_2016.3.210/linux/mkl/lib/intel64 -L /fusion/usc/opt/intel/compilers_and_libraries_2016.3.210/linux/mkl/include
SPECIAL   =  -r8 -I${MKLROOT}/include/intel64/ilp64 -I${MKLROOT}/include
